# 基础
APP_NAME=LogSentinel
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://logsentinel:logsentinel@localhost:5432/logsentinel
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX_CONN=50

# Loki
LOKI_URL=http://localhost:3100
LOKI_TIMEOUT=5

# 引擎
ENGINE_INTERVAL_SECONDS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
