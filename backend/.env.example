# LogSentinel 配置示例
# 复制此文件为 .env 并修改配�?
# 基础配置
APP_NAME=LogSentinel
DEBUG=false

# 环境变量配置

# 日志级别
LOG_LEVEL=INFO

# 数据库配置（Docker 环境中使用容器内路径）
DATABASE_URL=sqlite+aiosqlite:///./data/logsentinel.db

# Loki 配置（Docker 环境中使用服务名）
LOKI_URL=http://loki:3100
LOKI_TIMEOUT=5

# 引擎配置
ENGINE_INTERVAL_SECONDS=30

# CORS 配置（JSON 数组格式）
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://frontend:80"]
